# AI Stock Guardian API
# Copy this to .env and fill in your values

LLM_PROVIDER_API_KEY=sk-your-openai-api-key-here
LLM_PROVIDER_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o-mini
DATABASE_URL=sqlite+aiosqlite:///./data/guardian.db
JWT_SECRET_KEY=change-this-to-a-random-secret-string
FRED_API_KEY=
